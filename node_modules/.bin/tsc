#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/lon3walker/Desktop/Web_Dev_Cohort/Fullstack/Location_app_kafka/node_modules/.pnpm/tsc@2.0.4/node_modules/tsc/node_modules:/Users/lon3walker/Desktop/Web_Dev_Cohort/Fullstack/Location_app_kafka/node_modules/.pnpm/tsc@2.0.4/node_modules:/Users/lon3walker/Desktop/Web_Dev_Cohort/Fullstack/Location_app_kafka/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/lon3walker/Desktop/Web_Dev_Cohort/Fullstack/Location_app_kafka/node_modules/.pnpm/tsc@2.0.4/node_modules/tsc/node_modules:/Users/lon3walker/Desktop/Web_Dev_Cohort/Fullstack/Location_app_kafka/node_modules/.pnpm/tsc@2.0.4/node_modules:/Users/lon3walker/Desktop/Web_Dev_Cohort/Fullstack/Location_app_kafka/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/tsc@2.0.4/node_modules/tsc/bin/tsc" "$@"
else
  exec node  "$basedir/../.pnpm/tsc@2.0.4/node_modules/tsc/bin/tsc" "$@"
fi
